# ===========================================
# Storacha Marketplace - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env or any file with real secrets

# ===========================================
# Shared
# ===========================================
NODE_ENV=development

# ===========================================
# Blockchain (Base)
# ===========================================
# Get RPC URLs from: https://alchemy.com or https://infura.io
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Contract addresses — backend (used by Express server and indexer)
MARKETPLACE_CONTRACT_ADDRESS=
USDC_CONTRACT_ADDRESS=

# ===========================================
# Backend
# ===========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketplace
BACKEND_PORT=3001

# CORS - comma separated frontend URLs
CORS_ORIGINS=http://localhost:3000

# ===========================================
# Frontend
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Contract addresses — frontend (must be prefixed with NEXT_PUBLIC_)
# Base Sepolia USDC: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
NEXT_PUBLIC_USDC_ADDRESS=
# Set after contract deployment
NEXT_PUBLIC_MARKETPLACE_CONTRACT_ADDRESS=

# Chain config
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_CHAIN_NAME=Base Sepolia
NEXT_PUBLIC_BLOCK_EXPLORER_URL=

# ===========================================
# Contracts (Development Only)
# ===========================================
# NEVER commit real private keys
# Use a dedicated test wallet with no real funds
DEPLOYER_PRIVATE_KEY=
